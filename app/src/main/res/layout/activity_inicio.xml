<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Cabeçalho com nome do app e botão de logout -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">

        <!-- Nome do aplicativo no canto superior esquerdo -->
        <TextView
            android:id="@+id/appName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_alignParentStart="true" />

        <!-- Botão de logout no canto superior direito -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Sair"
            android:textSize="14sp"
            app:cornerRadius="8dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </RelativeLayout>

    <!-- Conteúdo principal no meio -->
    <LinearLayout
        android:id="@+id/conteudoPrincipal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_above="@id/barraXPLayout"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <!-- Metas SEM BORDAS ARREDONDADAS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white_transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/meta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯 Metas de Hoje"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:paddingBottom="8dp"/>

                <!-- Primeira meta fácil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/metaFacil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nenhuma meta fácil"
                        android:textSize="16sp"
                        android:textColor="@android:color/holo_green_light"/>
                </LinearLayout>

                <!-- Primeira meta média -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟠"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/metaMedio"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nenhuma meta média"
                        android:textSize="16sp"
                        android:textColor="@android:color/holo_orange_light"/>
                </LinearLayout>

                <!-- Primeira meta difícil -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔴"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/metaDificil"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nenhuma meta difícil"
                        android:textSize="16sp"
                        android:textColor="@android:color/holo_red_light"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Espaço para o gráfico SEM BORDAS ARREDONDADAS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white_transparent">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/graficoProgresso"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="8dp" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Barra de XP POSICIONADA ACIMA DOS BOTÕES -->
    <LinearLayout
        android:id="@+id/barraXPLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_above="@id/gradeBotoes"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="@color/white_transparent">

        <TextView
            android:id="@+id/tvLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nível 1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginBottom="4dp"/>

        <ProgressBar
            android:id="@+id/barraXP"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:backgroundTint="@android:color/darker_gray"
            android:max="100"
            android:progress="0"
            android:progressTint="@android:color/holo_blue_light" />

        <TextView
            android:id="@+id/tvXpTexto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/100 XP"
            android:textSize="12sp"
            android:textColor="@color/white"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- Grade de botões FIXADA na parte inferior -->
    <GridLayout
        android:id="@+id/gradeBotoes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:columnCount="3"
        android:alignmentMode="alignMargins"
        android:useDefaultMargins="true"
        android:rowCount="1"
        android:padding="8dp"
        android:background="@color/white_transparent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnAplicativos"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/apps"
                    android:contentDescription="@string/aplicativos"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Apps"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnMetas"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/goal"
                    android:contentDescription="Metas"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Metas"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnConfiguracao"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_columnWeight="1"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="8dp">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/conf"
                    android:contentDescription="Configuração"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Config"
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </GridLayout>

</RelativeLayout>