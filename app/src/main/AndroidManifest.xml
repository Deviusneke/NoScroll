<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissões de Rede -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permissões para monitoramento de apps -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions"/>
    <uses-permission android:name="android.permission.GET_PACKAGE_SIZE" />

    <!-- Permissões para o serviço de bloqueio -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />

    <!-- Para versões mais recentes do Android -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Permissão para mostrar popup sobre outros apps -->
    <uses-permission android:name="android.permission.SYSTEM_OVERLAY_WINDOW" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/noscroll"
        android:label="@string/app_name"
        android:roundIcon="@drawable/noscroll"
        android:supportsRtl="true"
        android:theme="@style/Theme.NoScroll"
        tools:targetApi="31">

        <!-- Activity Principal (Tela de Lançamento) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela de Login -->
        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Tela de Início -->
        <activity
            android:name=".ActivityInicio"
            android:exported="true" />

        <!-- Lista de Aplicativos -->
        <activity
            android:name=".AppListActivity"
            android:exported="true" />

        <!-- Detalhes/Configuração de Aplicativos -->
        <activity
            android:name=".AplicativosActivity"
            android:exported="true" />

        <!-- Lista de Todos os Aplicativos -->
        <activity
            android:name=".AppListActivity"
            android:exported="true" />

        <!-- Cadastro de Aplicativos -->
        <activity
            android:name=".CadastroAplicativo"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" />

        <!-- Configurações -->
        <activity
            android:name=".ConfiguracaoActivity"
            android:exported="true" />

        <!-- Criação de Metas -->
        <activity
            android:name=".CriarMetaActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize" />

        <!-- Lista de Metas -->
        <activity
            android:name=".MetasActivity"
            android:exported="true" />

        <!-- Configuração de Tempo -->
        <activity
            android:name=".TimeConfigurationActivity"
            android:exported="true" />

        <activity
            android:name=".CadastroUsuario"
            android:exported="true" />

        <activity
            android:name=".EditarPerfilActivity"
            android:exported="true" />

        <!-- Activity de Bloqueio (Popup que aparece quando o limite é atingido) -->
        <activity
            android:name=".BlockActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:taskAffinity=""
            android:theme="@style/Theme.AppCompat.NoActionBar" />

        <!-- Serviço de Monitoramento de Uso (verifica limites periodicamente) -->
        <service
            android:name=".service.UsageMonitorService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Serviço de Monitoramento de App em Primeiro Plano (verifica app atual) -->
        <service
            android:name=".service.AppUsageMonitor"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>